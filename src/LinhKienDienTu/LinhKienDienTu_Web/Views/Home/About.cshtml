@{
    ViewData["Title"] = "Về TopGearVN - Gaming Gear Pro Shop";
}

<style>
    
    .hero-banner {
        background: url('/images/gaming-background.jpg') center/cover no-repeat;
        padding: 80px 0;
        border-radius: 0 0 30px 30px;
        text-align: center;
        color: white;
    }

    
    .features-container {
        margin-top: 40px;
    }

    .feature-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        text-align: center;
        height: 100%; 
    }

    
    .partner-logo {
        max-height: 50px; 
        width: auto;
        object-fit: contain;
        opacity: 0.8;
        transition: 0.3s;
    }

        .partner-logo:hover {
            opacity: 1;
        }
</style>

<div class="hero-banner text-white text-center">
    <div class="container">
        <h1 class="display-3 fw-bold">TOPGEARVN - CÂU CHUYỆN CỦA CHÚNG TỒI</h1>
        <p class="lead">Level Up Your Game - Nâng tầm trải nghiệm đỉnh cao Gaming</p>
    </div>
</div>

<div class="container features-container">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="fas fa-shield-alt fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Hàng chính hãng</h5>
                <p class="text-muted small">Cam kết 100% sản phẩm có nguồn gốc rõ ràng, bảo hành đầy đủ.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="fas fa-shipping-fast fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Giao hàng nhanh</h5>
                <p class="text-muted small">Hệ thống vận chuyển chuyên nghiệp, giao hàng tận tay siêu tốc.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="fas fa-headset fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Tư vấn tận tâm</h5>
                <p class="text-muted small">Hỗ trợ kỹ thuật 24/7, giúp bạn chọn được "vũ khí" ưng ý nhất.</p>
            </div>
        </div>
    </div>
</div>
<div class="container about-section">
    <div class="row align-items-center">
        
        <div class="col-lg-6">
            <h2 class="fw-bold mb-3">Về TopGearVN</h2>
            <p class="text-muted" style="line-height: 1.8;">
                TopGearVN được thành lập với sứ mệnh mang đến trải nghiệm đỉnh cao cho cộng đồng game thủ tại Việt Nam. Chúng mình tin rằng, mỗi món gear không chỉ là thiết bị phần cứng, mà còn là công cụ giúp bạn khai phá tiềm năng, tạo nên những khoảnh khắc chiến thắng đầy cảm xúc trong từng trận đấu.
                <br><br>
                Xuất phát từ niềm đam mê mãnh liệt với công nghệ và khát khao nâng tầm tiêu chuẩn setup, TopGearVN luôn không ngừng chọn lọc những thương hiệu uy tín nhất thế giới để gửi gắm đến khách hàng. Với chúng mình, sự hài lòng của bạn chính là thước đo giá trị, và đó là lý do chúng mình luôn cam kết về chất lượng sản phẩm chính hãng, dịch vụ tư vấn tận tâm cùng chính sách hậu mãi chuyên nghiệp nhất.
            </p>
        </div>

        
        <div class="col-lg-6 text-center">
            <img src="/images/gaming-setup.jpg" class="gaming-setup-img" alt="Gaming Setup">
        </div>
    </div>
</div>
    </div>
</div
    </div>
</div>
<div class="container mt-5 text-center">
    <h4 class="mb-4">CÁC ĐỐI TÁC THƯƠNG HIỆU</h4>
    <div class="d-flex justify-content-center align-items-center flex-wrap gap-4">
        <img src="/images/logo-asus.png" class="partner-logo" alt="Asus">
        <img src="/images/logo-logitech.png" class="partner-logo" alt="Logitech">
        <img src="/images/logo-razer.png" class="partner-logo" alt="Razer">
        <img src="/images/logo-corsair.png" class="partner-logo" alt="Corsair">
    </div>
</div>
    
</div>